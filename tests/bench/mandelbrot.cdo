/* mandelbrot.cdo -- ASCII Mandelbrot at low resolution.
 *
 * Stresses: tight nested numeric loop, branchy escape test, no allocation
 * inside the hot path.  This is the classic JIT-vs-interpreter delta
 * benchmark: every operation is a typed double, ideal for trace
 * specialisation.
 *
 * Output is suppressed by computing a checksum instead of printing the
 * whole grid, so timing is dominated by arithmetic, not I/O.
 */

CONST W = 80;
CONST H = 40;
CONST MAX_ITER = 500;

VAR checksum = 0;

FOR py IN 0 -> H - 1 {
    VAR y0 = (py / H) * 2.0 - 1.0;
    FOR px IN 0 -> W - 1 {
        VAR x0 = (px / W) * 3.5 - 2.5;
        VAR x = 0.0;
        VAR y = 0.0;
        VAR iter = 0;
        WHILE iter < MAX_ITER {
            VAR x2 = x * x;
            VAR y2 = y * y;
            IF x2 + y2 > 4.0 { BREAK; }
            VAR xt = x2 - y2 + x0;
            y = 2.0 * x * y + y0;
            x = xt;
            iter = iter + 1;
        }
        checksum = checksum + iter;
    }
}

print(checksum);
