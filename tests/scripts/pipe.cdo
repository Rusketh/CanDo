/* pipe.cdo -- tests for pipe (~>), filter (~!>), and mask (~ / .) */
/* ~ = consume/pass   . = skip                                      */

/* ----- Pipe: map over array --------------------------------------------- */
var nums = [1, 2, 3, 4, 5];

var tens = nums ~> pipe * 10;
print(tens[0]);   /* expected: 10  */
print(tens[1]);   /* expected: 20  */
print(tens[4]);   /* expected: 50  */

var doubled = nums ~> {
    return pipe * 2;
};
print(doubled[0]);  /* expected: 2  */
print(doubled[2]);  /* expected: 6  */

/* ----- Filter ----------------------------------------------------------- */
var evens = nums ~!> {
    if pipe % 2 == 0 { return pipe; }
    return null;
};
print(evens[0]);  /* expected: 2  */
print(evens[1]);  /* expected: 4  */

var big = nums ~!> {
    if pipe > 3 { return pipe; }
};
print(big[0]);  /* expected: 4  */
print(big[1]);  /* expected: 5  */

/* ----- Mask: mixed (explicit per-position) ------------------------------ */
/* (~.~) 1, 3, 5  →  pass 1, skip 3, pass 5 */
var a, b = (~.~) 1, 3, 5;
print(a);  /* expected: 1  */
print(b);  /* expected: 5  */

/* ----- Mask: pure-~ (consume bits; extras outside mask are skipped) ----- */
/* (~) 1, 2  →  pass 1, skip 2 (outside pure-~ mask) */
var c = (~) 1, 2;
print(c);  /* expected: 1  */

/* (~~) 1, 2, 3  →  pass 1, pass 2; 3 outside and skipped */
var d, e = (~~) 1, 2, 3;
print(d);  /* expected: 1  */
print(e);  /* expected: 2  */

/* ----- Mask: pure-. (skip bits; extras outside mask are passed) --------- */
/* (.) 1, 2  →  skip 1, pass 2 (outside pure-. mask treated as ~) */
var f = (.) 1, 2;
print(f);  /* expected: 2  */

/* (..) 1, 2, 3  →  skip 1, skip 2; 3 outside and passed */
var g = (..) 1, 2, 3;
print(g);  /* expected: 3  */

/* ----- Mask: applied to a multi-return function ------------------------- */
/* getPos() returns 1, 2, 3; (~.~) keeps 1st and 3rd, skips 2nd */
function getPos() { return 1, 2, 3; }
var x, z = (~.~) getPos();
print(x);  /* expected: 1  */
print(z);  /* expected: 3  */

/* ----- Nested pipe body with returns on both sides of the inner pipe ----
 * Regression test: each pipe body's `return` patches must land at its
 * own OP_NULL fallthrough.  Previously the parser reset pipe_exit_count
 * to 0 when entering a nested body, so an inner return would overwrite
 * an outer return's already-recorded patch position; the outer scope
 * then re-patched the inner's bytecode and corrupted the program.
 * ---------------------------------------------------------------------- */
var nested = [1, 2, 3] ~> {
    if pipe == 1 { return 100; }
    var inner = [10, 20] ~> {
        if pipe == 10 { return 7; }
        return pipe + 1;
    };
    if pipe == 2 { return inner[0]; }
    return inner[1];
};
print(nested[0]);  /* expected: 100 */
print(nested[1]);  /* expected: 7   */
print(nested[2]);  /* expected: 21  */
