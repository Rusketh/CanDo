/* arithmetic.cdo -- operators, precedence, compound assignment, bitwise */

/* Basic arithmetic */
print(1 + 2);
print(10 - 3);
print(4 * 5);
print(15 / 3);
print(10 % 3);
print(2 ^ 8);

/* Unary */
print(-5);
print(-(3 - 10));

/* Precedence */
print(2 + 3 * 4);
print((2 + 3) * 4);

/* Postfix ++ and -- */
VAR n = 10;
n++;
print(n);
n--;
print(n);

/* Compound assignment */
VAR x = 10;
x += 5;
print(x);
x -= 3;
print(x);
x *= 2;
print(x);
x /= 4;
print(x);
x %= 4;
print(x);

/* Bitwise */
print(6 & 3);
print(6 | 3);
print(1 << 4);
print(32 >> 2);

/* Integer power */
print(3 ^ 3);
