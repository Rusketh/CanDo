VAR a = [1, 2, 3];
print("a:length(): ", a:length());

a:push(4);
print("a after push: ", a);

VAR popped = a:pop();
print("popped: ", popped);
print("a after pop: ", a);

VAR doubled = a:map(FUNCTION(x) { RETURN x * 2; });
print("doubled: ", doubled);

VAR even = doubled:filter(FUNCTION(x) { RETURN x > 3; });
print("even > 3: ", even);

VAR sum = a:reduce(FUNCTION(acc, x) { RETURN acc + x; }, 0);
print("sum of a: ", sum);
