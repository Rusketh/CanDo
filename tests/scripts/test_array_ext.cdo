/* test_array_ext.cdo -- Tests for extended array library functions.
 *
 * Tests: splice, remove, copy, and index-based push.
 * Uses assertions (throws on failure) so run_smoke can verify exit code.
 */

function assert(cond, msg) {
    if !cond {
        throw msg;
    }
}

/* ----- array.push with index ---------------------------------------------- */
var a = [10, 30];
a:push(1, 20);   /* insert 20 at index 1 → [10, 20, 30] */
assert(a:length() == 3, "push(idx): length");
assert(a[0] == 10, "push(idx): a[0]");
assert(a[1] == 20, "push(idx): a[1]");
assert(a[2] == 30, "push(idx): a[2]");

/* Append at end (original behaviour). */
a:push(40);
assert(a:length() == 4, "push(append): length");
assert(a[3] == 40, "push(append): a[3]");

/* ----- array.splice ------------------------------------------------------- */
var b = [1, 2, 3, 4, 5];
var removed = b:splice(1, 2);   /* remove 2 elements starting at index 1 */
assert(b:length() == 3, "splice: remaining length");
assert(b[0] == 1, "splice: b[0]");
assert(b[1] == 4, "splice: b[1]");
assert(b[2] == 5, "splice: b[2]");
assert(removed:length() == 2, "splice: removed length");
assert(removed[0] == 2, "splice: removed[0]");
assert(removed[1] == 3, "splice: removed[1]");

/* Splice to end (no len argument). */
var c = [10, 20, 30, 40];
var tail = c:splice(2);   /* remove from index 2 to end */
assert(c:length() == 2, "splice(no len): remaining length");
assert(tail:length() == 2, "splice(no len): tail length");
assert(tail[0] == 30, "splice(no len): tail[0]");
assert(tail[1] == 40, "splice(no len): tail[1]");

/* ----- array.remove ------------------------------------------------------- */
var d = [100, 200, 300];
var v = d:remove(1);
assert(v == 200, "remove: returned value");
assert(d:length() == 2, "remove: remaining length");
assert(d[0] == 100, "remove: d[0]");
assert(d[1] == 300, "remove: d[1]");

/* Remove out of bounds returns null. */
var oob = d:remove(99);
assert(oob == null, "remove oob: null");
assert(d:length() == 2, "remove oob: length unchanged");

/* ----- array.copy --------------------------------------------------------- */
var e = [1, 2, 3];
var f = e:copy();
f[0] = 99;
assert(e[0] == 1, "copy: src unchanged");
assert(f[0] == 99, "copy: dst modified");
assert(f:length() == 3, "copy: length");
assert(f[1] == 2, "copy: f[1]");
assert(f[2] == 3, "copy: f[2]");

/* ----- indexOf / lastIndexOf / includes ----------------------------------- */
var q = [1, 2, 3, 2, 1];
assert(q:indexOf(2)       == 1,  "indexOf: first match");
assert(q:indexOf(2, 2)    == 3,  "indexOf: from-index");
assert(q:indexOf(99)      == -1, "indexOf: not found");
assert(q:lastIndexOf(2)   == 3,  "lastIndexOf: last match");
assert(q:lastIndexOf(99)  == -1, "lastIndexOf: not found");
assert(q:includes(3)      == true,  "includes: yes");
assert(q:includes(99)     == false, "includes: no");
assert(q:contains(1)      == true,  "contains: alias");

/* ----- find / findIndex / findLast / findLastIndex / some / every --------- */
assert(q:find(function(x){ return x > 2; })           == 3,  "find");
assert(q:findIndex(function(x){ return x > 2; })      == 2,  "findIndex");
assert(q:findLast(function(x){ return x > 2; })       == 3,  "findLast");
assert(q:findLastIndex(function(x){ return x > 2; })  == 2,  "findLastIndex");
assert(q:some(function(x){ return x > 4; })           == false, "some: none");
assert(q:some(function(x){ return x > 2; })           == true,  "some: any");
assert(q:every(function(x){ return x > 0; })          == true,  "every: all");
assert(q:every(function(x){ return x > 1; })          == false, "every: not all");

/* ----- forEach + at -------------------------------------------------------- */
var seen = 0;
[10, 20, 30]:forEach(function(v, i){ seen = seen + v + i; });
assert(seen == 63, "forEach: sums of v+i");
assert([10, 20, 30]:at(0)  == 10, "at: positive index");
assert([10, 20, 30]:at(-1) == 30, "at: negative index");
assert([10, 20, 30]:at(-3) == 10, "at: negative wrap");
assert([10, 20, 30]:at(99) == null, "at: out-of-range");

/* ----- slice / concat / join ---------------------------------------------- */
var s = [1, 2, 3, 4, 5];
assert(s:slice(1, 4):join(",") == "2,3,4", "slice: middle");
assert(s:slice(-2):join(",")    == "4,5",   "slice: negative start");
assert(s:slice():length()       == 5,        "slice: no args = copy");
var c = [1]:concat([2, 3], [4, 5]);
assert(c:length() == 5, "concat: total");
assert(c:join(",") == "1,2,3,4,5", "concat: join");
assert([1, 2, 3]:join("-") == "1-2-3", "join: separator");

/* ----- reverse / sort / shift / unshift / fill --------------------------- */
var r = [3, 1, 2];
r:reverse();
assert(r:join(",") == "2,1,3", "reverse");
r:sort();
assert(r:join(",") == "1,2,3", "sort: default");
r:sort(function(a, b){ return b - a; });
assert(r:join(",") == "3,2,1", "sort: comparator desc");

var u = [1, 2, 3];
assert(u:shift() == 1, "shift: head");
assert(u:length() == 2, "shift: length");
assert(u:unshift(0)  == 3, "unshift: new length");
assert(u:join(",") == "0,2,3", "unshift: position");
assert(u:unshift(-2, -1)  == 5, "unshift: multi");
assert(u:join(",") == "-2,-1,0,2,3", "unshift: order");

var ff = [1, 2, 3, 4];
ff:fill(0, 1, 3);
assert(ff:join(",") == "1,0,0,4", "fill: range");

/* ----- flat / flatMap / reduceRight --------------------------------------- */
assert([[1,2],[3,4]]:flat():join(",") == "1,2,3,4", "flat");
assert([1,2,3]:flatMap(function(x){ return [x, x*2]; }):join(",")
       == "1,2,2,4,3,6", "flatMap");
assert(["a","b","c"]:reduceRight(function(acc,v){ return acc + v; }, "")
       == "cba", "reduceRight");

/* ----- unique / set ops --------------------------------------------------- */
assert([1, 2, 2, 3, 3, 3]:unique():join(",") == "1,2,3", "unique");
assert([1,2,3]:intersection([2,3,4]):join(",") == "2,3", "intersection");
assert([1,2,3]:union([3,4,5]):join(",") == "1,2,3,4,5", "union");
assert([1,2,3]:difference([2,4]):join(",") == "1,3", "difference");

print("test_array_ext: all assertions passed");
