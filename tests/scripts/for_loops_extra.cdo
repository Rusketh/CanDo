/* for_loops_extra.cdo -- coverage for FOR-IN edge cases that the bench
 * fix in vm.c (3-slot iterator state, snapshot-array path) introduced.
 *
 * Specifically:
 *   1. FOR k IN plainObject  -- exercises the FIFO-snapshot path
 *   2. FOR v OF plainObject  -- snapshot path, values mode
 *   3. RETURN from inside FOR-IN -- exercises OP_RETURN's loop_save
 *      unwind so the loop frame the function leaves open does not
 *      bleed into the caller's BREAK/CONTINUE depth math.
 *   4. Empty array / empty object iteration
 *   5. Nested FOR-IN with break from inner loop
 */

/* 1. Plain object, keys (FOR IN preserves declaration order via FIFO). */
VAR o = {x: 10, y: 20, z: 30};
FOR k IN o {
    print(k);
}

/* 2. Plain object, values. */
FOR v OF o {
    print(v);
}

/* 3. RETURN from inside FOR-IN.  If OP_RETURN does not unwind
 * vm->loop_depth, the caller's subsequent BREAK math reads a stale
 * frame.  We make the failure visible by following the call with an
 * outer FOR-IN + inner BREAK -- a stale frame would either crash or
 * jump to a garbage break_ip.  The expected output is just "ok" plus
 * the outer-loop emission. */
FUNCTION early_return(arr) {
    FOR v OF arr {
        IF v == 99 { RETURN "ok"; }
    }
    RETURN "fallthrough";
}
print(early_return([1, 2, 99, 4]));

VAR caller_seen = 0;
FOR i IN 1 -> 5 {
    caller_seen = caller_seen + 1;
    IF i == 3 { BREAK; }
}
print(caller_seen);

/* 4. Empty iterables. */
VAR empty_arr = [];
VAR ec = 0;
FOR v OF empty_arr {
    ec = ec + 1;
}
print(ec);

VAR empty_obj = {};
FOR k IN empty_obj {
    ec = ec + 1;
}
print(ec);

/* 5. Nested FOR-IN; inner BREAK must not derail outer. */
FOR a IN 1 -> 3 {
    FOR b IN 1 -> 3 {
        IF b == 2 { BREAK; }
        print(`${a}:${b}`);
    }
}
