/* for_loops.cdo -- FOR IN with ranges and arrays */

/* Ascending range: 1 -> N includes both endpoints */
FOR i IN 1 -> 4 {
    print(i);
}

/* Descending range */
FOR i IN 3 <- 1 {
    print(i);
}

/* FOR IN over array */
VAR nums = [100, 200, 300];
FOR v OF nums {
    print(v);
}

/* Range sum */
VAR sum = 0;
FOR i IN 1 -> 5 {
    sum = sum + i;
}
print(sum);

/* Nested FOR */
FOR row IN 1 -> 2 {
    FOR col IN 1 -> 2 {
        print(row * 10 + col);
    }
}

/* FOR with local variables inside */
FOR i IN 1 -> 3 {
    VAR sq = i * i;
    print(sq);
}
