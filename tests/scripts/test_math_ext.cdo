/* test_math_ext.cdo -- Tests for the extended math library.
 *
 * Covers: trunc, tanh, cbrt, log2, fround, hypot.
 */

function assert(cond, msg) { if !cond { throw msg; } }

assert(math.trunc(3.7) == 3,     "trunc: 3.7 -> 3");
assert(math.trunc(-3.7) == -3,   "trunc: -3.7 -> -3");
assert(math.trunc(0) == 0,        "trunc: 0");

assert(math.tanh(0) == 0,         "tanh: 0");

/* cbrt: cube root.  cbrt(27) ≈ 3 (floating-point precision). */
var c = math.cbrt(27);
assert(c > 2.999 && c < 3.001, "cbrt: 27 ≈ 3");
assert(math.cbrt(0) == 0,         "cbrt: 0");

assert(math.log2(1) == 0,         "log2: 1");
assert(math.log2(1024) == 10,     "log2: 1024");

assert(math.hypot(3, 4) == 5,     "hypot: 3,4");
assert(math.hypot(1, 2, 2) == 3,  "hypot: 1,2,2");
assert(math.hypot(0) == 0,         "hypot: 0");

/* fround truncates to single-precision; ~1/3 differs slightly. */
var f = math.fround(0.1);
assert(f > 0.099 && f < 0.101, "fround: 0.1 close");

print("test_math_ext: all assertions passed");
