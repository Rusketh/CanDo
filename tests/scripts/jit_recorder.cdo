/* jit_recorder.cdo -- end-to-end test of the Phase 3.3a recorder.
 *
 * Verifies:
 *   1. A WHILE loop in a function with only recordable opcodes
 *      (load_local, const, lt, jump_if_false, add, def_local, loop)
 *      compiles exactly one trace.
 *   2. trace_aborts stays at zero on the recordable path.
 *   3. The hot PC is auto-blacklisted so subsequent calls don't
 *      re-trigger.
 *   4. A loop containing an unrecordable op (string concat) aborts.
 *
 * The recorder doesn't execute traces yet (Phase 3.4) so behaviour
 * is unchanged whether the trace compiled or not -- the script's
 * outputs are produced by the interpreter as usual.
 */

jit.on();

FUNCTION run_clean() {
    VAR i = 0;
    VAR sum = 0;
    WHILE i < 200 {
        sum = sum + i;
        i = i + 1;
    }
    RETURN sum;
}
print(run_clean());                 // 19900

VAR s1 = jit.stats();
print(s1.traces_compiled);          // 1
print(s1.trace_aborts);             // 0
print(s1.hot_pcs);                  // 1
print(s1.blacklisted_pcs);          // 1

/* Calling run_clean again does NOT trigger another trace -- the PC is
 * already blacklisted from the first call.  But the SECOND call's
 * iterations all flow through the cached trace via the IR-interpreter,
 * so trace_iters jumps. */
VAR iters_before = jit.stats().trace_iters;
run_clean();
VAR s2 = jit.stats();
print(s2.traces_compiled);          // still 1
print(s2.trace_starts);             // still 1
print(s2.trace_iters > iters_before);   // true: second call ran via IR
print(s2.trace_iters >= 200);           // true: at least 200 trace iters

/* A separate function with a loop containing an unrecordable op
 * (string operations are not yet recordable -- Phase 3.3b). */
FUNCTION run_dirty() {
    VAR i = 0;
    VAR s = "";
    WHILE i < 200 {
        s = s + "x";   /* string concat -> string-typed OP_ADD; recorder aborts */
        i = i + 1;
    }
    RETURN i;
}
print(run_dirty());                 // 200

VAR s3 = jit.stats();
print(s3.traces_compiled);          // still 1 (the dirty loop aborted)
print(s3.trace_aborts > 0);         // true

/* Regression: bool stored to a local must not be downgraded to a
 * number under JIT (early Phase 3.4a wrote vm->stack[slot] =
 * cando_number(...) unconditionally, breaking IF on bool slots). */
FUNCTION bool_store() {
    VAR i = 0;
    VAR last = FALSE;
    WHILE i < 200 {
        last = i < 100;
        i = i + 1;
    }
    RETURN last;
}
print(bool_store());                // expect "false", not "0"

/* Regression: a DIV that raises in bytecode must NOT be silently
 * swallowed by the trace.  Phase 3.4a's DIV recording let prior
 * SSTOREs commit before the failing op, then bytecode resumed at
 * start_pc and skipped the error.  Phase 4 fix: emit IR_NEQ + a
 * snapshot-protected IR_GUARD_TRUE before IR_DIV; on guard fail,
 * iteration-local SSTOREs are rolled back and bytecode resumes
 * cleanly so the runtime error surfaces normally. */
FUNCTION div_zero() {
    VAR i = 0; VAR sum = 0; VAR d = 5;
    WHILE i < 200 {
        sum = sum + (10 / d);
        i = i + 1;
        IF i == 100 { d = 0; }
    }
    RETURN sum;
}
TRY {
    div_zero();
    print("no-error");              // wrong if reached
} CATCH (e) {
    print("caught");                // expected
}

/* Phase 3.3c: FOR-IN over a range traces via OP_FOR_NEXT (values
 * mode + IR_AREF).  Result must match bytecode. */
FUNCTION sum_range() {
    VAR sum = 0;
    FOR i IN 1 -> 200 { sum = sum + i; }
    RETURN sum;
}
print(sum_range());                 // expect 20100

/* Phase 3.3d: top-level (global-variable) loops.  Hot enough to
 * trigger; result must match bytecode.  This test deliberately uses
 * the global slot (no FUNCTION wrapper) so the trace exercises
 * IR_GLOAD / IR_GSTORE. */
VAR g_i = 0;
VAR g_sum = 0;
WHILE g_i < 200 {
    g_sum = g_sum + g_i;
    g_i = g_i + 1;
}
print(g_sum);                       // 19900
print(jit.stats().traces_compiled >= 3);

/* Phase 4.1: snapshot rollback on a div-by-zero where prior
 * iteration writes to a global have committed.  Without GSTORE
 * rollback the trace's mid-iter GSTORE leaks past the side-exit and
 * bytecode then re-applies it, double-counting.  The catch block
 * must observe `committed` at the right value. */
VAR committed = 0;
FUNCTION div_rollback() {
    VAR i = 0;
    VAR d = 5;
    WHILE i < 200 {
        committed = committed + 1;     // GSTORE before the DIV guard
        i = i + 1;                     // SSTORE before the DIV guard
        IF i == 100 { d = 0; }
        VAR x = 10 / d;                // div-by-zero on the iter where d==0
    }
}
TRY { div_rollback(); } CATCH (e) {}
/* Bytecode-only result: the loop runs iters 1..100 (raising on
 * iter 100 where d becomes 0), so committed == 100.  A buggy rollback
 * that fails to restore the global on the trace's IF-guard side-exit
 * would over-count: trace's GSTORE leaks past the exit, then bytecode
 * re-runs the iter and increments again. */
print(committed);                       // 100

/* Phase 4.1: traces_evicted is a stat surfaced by jit.stats().  Just
 * confirm it's reachable and zero in this test (we don't push enough
 * distinct loops to trigger eviction). */
print(jit.stats().traces_evicted);     // 0

/* Phase 4.2: tight loops calling a registered fast-native (math.sqrt)
 * compile a trace that emits IR_CALL_F1, dispatching to libm sqrt
 * directly without the VM-stack-passing convention.  The recorder
 * shadows OP_LOAD_GLOBAL of the math object via stack_aux, then
 * OP_GET_FIELD resolves "sqrt" to a fast-native at record time. */
FUNCTION sqrt_sum() {
    VAR s = 0;
    FOR i IN 1 -> 200 {
        s = s + math.sqrt(i);
    }
    RETURN s;
}
print(sqrt_sum() > 1892);              // true (sum ≈ 1892.48)
print(sqrt_sum() < 1893);              // true

/* Phase 4.3: same-chunk user-function inlining.  A loop calling a
 * small no-upvalue closure should compile a single trace that
 * absorbs the callee's body without aborting on the frame change. */
FUNCTION add(a, b) { RETURN a + b; }
FUNCTION inline_sum() {
    VAR s = 0;
    FOR i IN 1 -> 200 {
        s = s + add(i, 2);
    }
    RETURN s;
}
print(inline_sum());                   // 1+2+...+200 + 200*2 = 20500

/* Confirm at least one trace closed cleanly (the inline_sum loop)
 * AND no aborts crept in between sqrt_sum and inline_sum. */
VAR s4 = jit.stats();
print(s4.traces_compiled >= 4);        // true (run_clean, sum_range, top-level, inline_sum)

/* Phase 4.3: a two-level inline (outer fn calls helper which calls
 * helper).  Verifies CANDO_JIT_MAX_INLINE_DEPTH > 1 actually works,
 * not just that depth=1 traces. */
FUNCTION twice(x) { RETURN add(x, x); }
FUNCTION nested_sum() {
    VAR s = 0;
    FOR i IN 1 -> 200 {
        s = s + twice(i);
    }
    RETURN s;
}
print(nested_sum());                   // 2*(1+2+...+200) = 40200

/* Phase 4.3: OP_RETURN at the recording-frame boundary aborts -- a
 * loop body that itself returns shouldn't trace.  We don't have a
 * direct stat for "this specific case aborted", so just confirm the
 * answer is right and traces_compiled didn't go up unexpectedly. */
VAR aborts_before = jit.stats().trace_aborts;
FUNCTION early_return() {
    VAR s = 0;
    VAR i = 0;
    WHILE i < 200 {
        i = i + 1;
        s = s + i;
        IF i == 50 { RETURN s; }   // mid-loop RETURN
    }
    RETURN s;
}
print(early_return());                 // 1+2+...+50 = 1275
print(jit.stats().trace_aborts >= aborts_before);  // true (>=, not strict)

/* Phase 4.3 review-fix: recursion gets a dedicated abort reason
 * rather than bouncing against the depth cap. */
FUNCTION fib(n) {
    IF n < 2 { RETURN n; }
    RETURN fib(n - 1) + fib(n - 2);
}
VAR rec_sum = 0;
FOR i IN 1 -> 200 { rec_sum = rec_sum + fib(5); }
print(rec_sum);                        // 200 * 5 = 1000
print(jit.stats().last_abort);         // "OP_CALL: recursion detected"

/* Phase 4.3 review-fix: a loop inside an inlined call fast-fails
 * with a clear abort reason instead of bouncing against the trace
 * length cap. */
FUNCTION inner_loop(n) {
    VAR s = 0;
    VAR k = 0;
    WHILE k < n { s = s + k; k = k + 1; }
    RETURN s;
}
VAR loop_sum = 0;
FOR i IN 1 -> 200 { loop_sum = loop_sum + inner_loop(3); }
print(loop_sum);                       // 200 * (0+1+2) = 600
print(jit.stats().last_abort);         // "loop inside inlined call (v1 limitation)"

/* Phase 5d/5e: FOLD + CSE.  Algebraic identities (x+0, x*1, x-0)
 * collapse at IR-emit time; constant folding evaluates KNUM op KNUM
 * eagerly; CSE merges duplicate pure ops within a trace.  Result
 * must still be correct -- both paths compute the same number. */
FUNCTION fold_cse() {
    VAR s = 0;
    FOR i IN 1 -> 200 {
        VAR x = (i + 0) * 1;        // -> i  (FOLD)
        VAR y = (i * 2) + (i * 2);  // -> 4*i, the second i*2 CSE-reused
        s = s + x + y;
    }
    RETURN s;
}
print(fold_cse());                     // (1+...+200) + 4*(1+...+200) = 5*20100 = 100500

/* Phase 5g: GLOAD store-to-load forwarding.  Within one trace iter
 * a store to a global makes the next IR_GLOAD of the same name
 * forward to the stored IRRef instead of emitting a fresh load.
 * Result must still match the bytecode-only path. */
VAR fwd_g = 0;
VAR fwd_sum = 0;
WHILE fwd_g < 200 {
    fwd_g = fwd_g + 1;       /* GSTORE; updates cur_global_value[fwd_g] */
    fwd_sum = fwd_sum + fwd_g;
}
print(fwd_sum);                        // 1+2+...+200 = 20100

/* Phase 5h: DSE.  An SSTORE/GSTORE that is overwritten by a later
 * store to the same slot/global with no intervening read is dead
 * and gets NOP'd in-place.  The trace must still produce the right
 * answer. */
FUNCTION dse_check() {
    VAR s = 0;
    FOR i IN 1 -> 200 {
        VAR t = i + 1;       /* dead: overwritten next line */
        t = i * 2;           /* live: feeds s */
        s = s + t;
    }
    RETURN s;
}
print(dse_check());                    // 2*(1+...+200) = 40200

/* Phase 5i: DCE.  After DSE NOPs the redundant store, the value-IR
 * that fed it (an IR_ADD here) becomes unreachable and gets NOPped
 * in turn.  This case has TWO layers of dead computation -- a chain
 * of arithmetic that's all rooted at the dead store. */
FUNCTION dce_check() {
    VAR s = 0;
    FOR i IN 1 -> 200 {
        VAR t = (i + 1) * (i - 1);   /* whole expression dead */
        t = i;                        /* live */
        s = s + t;
    }
    RETURN s;
}
print(dce_check());                    // 1+2+...+200 = 20100

/* Phase 6.1: native codegen for the counter-loop subset.  This
 * trace uses only ops that the x86_64 emitter supports (KNUM,
 * SLOAD, SSTORE, ADD, LT, GUARD_TRUE, LOOP), so the recorder
 * compiles it down to mcode and the IR-interpreter is bypassed.
 * The script-visible result must match the bytecode-only path. */
FUNCTION counter_native() {
    VAR i = 0;
    WHILE i < 10000 {
        i = i + 1;
    }
    RETURN i;
}
print(counter_native());               // 10000

/* Phase 6.3: IR_CALL_F1 codegen.  A loop calling math.sqrt on a
 * local emits IR_CALL_F1 in the recorder; codegen translates that
 * to a direct `call sqrt` from the loop body.  This trace is
 * fully native (no globals, no arrays) so the codegen actually
 * fires. */
FUNCTION sqrt_local_native() {
    VAR x = 4.0;
    VAR s = 0;
    VAR i = 0;
    WHILE i < 100 {
        s = s + math.sqrt(x);    /* sqrt(4) = 2 every iter */
        i = i + 1;
    }
    RETURN s;
}
print(sqrt_local_native());             /* 100 * 2 = 200 */

/* Phase 6.4: IR_GLOAD + IR_GSTORE codegen.  A top-level loop that
 * reads/writes globals every iteration goes through the JIT helpers
 * cando_jit_gload_for_mcode / cando_jit_gstore_for_mcode emitted as
 * direct calls.  The trace's bad-type side-exit reuses the per-
 * guard stub mechanism with cur_snap from the latest guard. */
VAR g_cnt = 0;
WHILE g_cnt < 200 {
    g_cnt = g_cnt + 1;
}
print(g_cnt);                           /* 200 */

/* Phase 6.5: IR_HLOAD_SLOT + IR_AREF codegen.  FOR-IN over a range
 * emits these to walk the source array without re-resolving the
 * handle every iteration.  cando_jit_hload_slot_for_mcode and
 * cando_jit_aref_for_mcode are the JIT helpers; bad-type side-exits
 * use cur_snap. */
VAR for_sum = 0;
FOR i IN 1 -> 200 {
    for_sum = for_sum + i;
}
print(for_sum);                         /* 1+...+200 = 20100 */

/* Phase 6.7: self-op arithmetic peephole.  When both operands of a
 * binary op are the same IRRef (e.g. squaring x*x), codegen loads
 * once into xmm0 and uses the addsd/mulsd-self variant instead of
 * loading the same value into xmm1 too.  Result must still match
 * the bytecode-only path. */
FUNCTION square_sum() {
    VAR s = 0;
    FOR i IN 1 -> 100 {
        s = s + i * i;        /* IR_MUL #ref #ref -> peephole hits */
    }
    RETURN s;
}
print(square_sum());                    /* sum of i*i for i=1..100 = 338350 */

/* Phase 4.4a-c: allocate an array literal in a hot loop, store it
 * to a local, read element 0.  Trace records IR_NEW_ARRAY +
 * IR_ARRAY_APPEND + IR_SSTORE(OBJ) + IR_SLOAD(OBJ) + IR_INDEX_GET.
 * Codegen bails (no codegen for these yet -- Phase 4.4g) so the
 * trace runs through the IR-interpreter; the result must match
 * the bytecode-only path.  Allocations are NOT marked invariant
 * by LICM (see mark_loop_invariants special case). */
VAR arr_sum = 0;
FOR k IN 1 -> 200 {
    VAR a = [k, k * 2];
    arr_sum = arr_sum + a[0];
}
print(arr_sum);                         /* 1+2+...+200 = 20100 */

print("DONE");
