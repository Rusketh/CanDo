/* variables.cdo -- VAR, CONST, assignment, multi-var */

/* Basic VAR */
VAR a = 42;
print(a);

/* CONST */
CONST PI = 3;
print(PI);

/* Reassignment */
VAR x = 1;
x = 99;
print(x);

/* Multi-var declaration */
VAR p, q = 10, 20;
print(p);
print(q);

/* VAR in block scope */
IF TRUE {
    VAR local = 77;
    print(local);
}

/* Multiple vars in sequence */
VAR i = 5;
VAR j = 6;
VAR k = i + j;
print(k);
