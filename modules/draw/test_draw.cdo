// modules/draw/test_draw.cdo -- end-to-end script test for the draw
// module.  Exercises every primitive, the transform stack, image
// loading + draw.draw, and font loading + font:getWidth/getHeight.
// Requires a running X display; CI runs this under `xvfb-run -a`.

VAR window = include("../window/window.so");
VAR draw   = include("./draw.so");

VAR fails = 0;
VAR passes = 0;

VAR EXPECT = FUNCTION(name, ok) {
    IF ok {
        print(`  PASS  ${name}`);
        passes = passes + 1;
    } ELSE {
        print(`  FAIL  ${name}`);
        fails = fails + 1;
    }
};

print("== draw: namespace surface ==");
EXPECT("VERSION is a string",       type(draw.VERSION)      == "string");
EXPECT("clear is a function",       type(draw.clear)        != "null");
EXPECT("setColor is a function",    type(draw.setColor)     != "null");
EXPECT("rectangle is a function",   type(draw.rectangle)    != "null");
EXPECT("circle is a function",      type(draw.circle)       != "null");
EXPECT("line is a function",        type(draw.line)         != "null");
EXPECT("setScissor is a function",  type(draw.setScissor)   != "null");
EXPECT("push/pop functions",
    type(draw.push) != "null" && type(draw.pop) != "null");
EXPECT("translate/scale/rotate/origin",
    type(draw.translate) != "null" && type(draw.scale) != "null" &&
    type(draw.rotate) != "null"    && type(draw.origin) != "null");
EXPECT("newImage / draw.draw",
    type(draw.newImage) != "null" && type(draw.draw) != "null");
EXPECT("newFont / setFont / print",
    type(draw.newFont) != "null" && type(draw.setFont) != "null" &&
    type(draw.print) != "null");

print("== draw: image loading ==");
// Use a 4x4 RGBA test PNG generated by the CI pipeline (or by the
// caller).  The script is robust against the file not existing --
// it skips the image tests in that case.
VAR test_png = "/tmp/test4x4.png";
VAR have_png = file.exists(test_png);
IF have_png {
    VAR img = draw.newImage(test_png);
    EXPECT("type(img) == \"draw_image\"", type(img) == "draw_image");
    EXPECT("img.width == 4",  img.width  == 4);
    EXPECT("img.height == 4", img.height == 4);
    EXPECT("img:getWidth()/getHeight()",
        img:getWidth() == 4 && img:getHeight() == 4);
    VAR iw, ih = img:getDimensions();
    EXPECT("getDimensions multi-return", iw == 4 && ih == 4);
    img:setFilter("nearest");
    EXPECT("setFilter(\"nearest\") returned ok", true);
    img:release();
    EXPECT("release() succeeded", true);
} ELSE {
    print("  SKIP  /tmp/test4x4.png missing -- image tests skipped");
}

print("== draw: font loading ==");
VAR fontpath = "/usr/share/fonts/truetype/liberation/LiberationSans-Regular.ttf";
VAR have_font = file.exists(fontpath);
IF have_font {
    VAR fnt = draw.newFont(fontpath, 16);
    EXPECT("type(fnt) == \"draw_font\"", type(fnt) == "draw_font");
    EXPECT("font:getHeight() > 0", fnt:getHeight() > 0);
    EXPECT("font:getWidth(\"\") == 0", fnt:getWidth("") == 0);
    EXPECT("font:getWidth(\"hi\") > 0", fnt:getWidth("hi") > 0);
    fnt:release();
} ELSE {
    print("  SKIP  liberation sans missing -- font tests skipped");
}

print("== draw: primitives in a window ==");
VAR w = window.create("draw test", 200, 150);
VAR drew = 0;
w.draw = FUNCTION(self) {
    drew = drew + 1;
    draw.clear(0.1, 0.1, 0.1);
    draw.setColor(1, 0, 0);
    draw.rectangle("fill", 10, 10, 40, 30);
    draw.setColor(0, 1, 0);
    draw.rectangle("line", 60, 10, 40, 30);
    draw.setColor(0, 0.5, 1);
    draw.circle("fill", 150, 30, 15);
    draw.setColor(1, 1, 1);
    draw.line(10, 80, 190, 80);
    draw.push();
    draw.translate(100, 110);
    draw.rotate(0.4);
    draw.setColor(1, 0, 1);
    draw.rectangle("fill", -20, -10, 40, 20);
    draw.pop();
    draw.setScissor(0, 0, 100, 100);
    draw.setColor(1, 1, 0);
    draw.rectangle("fill", 0, 0, 200, 200);
    draw.setScissor();
};

thread {
    thread.sleep(150);
    EXPECT("draw fired in 150ms", drew > 0);
    w:close();
    thread.sleep(20);
    print(`Results: ${passes} passed, ${fails} failed`);
    IF fails > 0 { os.exit(1); }
};
